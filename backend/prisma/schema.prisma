// Database connection
datasource db {
  provider = "postgresql"
}

// Prisma Client generator
generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  projects  Project[]
  pomodoros PomodoroSession[]

  noteFolders NoteFolder[]
  notes       Note[]
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ON_HOLD
  CANCELLED
}

model Project {
  id            String @id @default(uuid())
  title         String
  description   String?
  color         String @default("#3B82F6")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  status       ProjectStatus @default(ACTIVE)
  completedAt  DateTime?
  isArchived   Boolean       @default(false)

  userId        String
  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)

  goals         Goal[]
  pomodoros     PomodoroSession[]
}

enum Recurrence {
  DAILY
  WEEKLY
  MONTHLY
}

model Goal {
  id            String @id @default(uuid())
  title         String
  description   String?
  isCompleted   Boolean @default(false)
  order         Int     @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  completedAt   DateTime?
  dueDate       DateTime?
  recurrence    Recurrence?

  projectId     String
  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model PomodoroSession {
  id            String @id @default(uuid())
  duration      Int // u minutama (default 25)
  startTime     DateTime
  endTime       DateTime?
  completed     Boolean @default(false)
  createdAt     DateTime @default(now())

  userId        String
  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId     String?
  project       Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model NoteFolder {
  id            String       @id @default(uuid())
  name          String
  color         String       @default("#6636F1")
  order         Int          @default(0)
  parentId      String?
  parent        NoteFolder?  @relation("FolderChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children      NoteFolder[] @relation("FolderChildren")
  notes         Note[]
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Note {
  id            String     @id @default(uuid())
  title         String
  content       String?    @db.Text
  order         Int        @default(0)
  folderId      String
  folder        NoteFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}
